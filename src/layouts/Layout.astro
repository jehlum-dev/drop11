---
import '../styles/global.css';
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <style>
        .float-fast { animation: float 6s ease-in-out infinite; }
        .float-slow { animation: float 10s ease-in-out infinite reverse; }
        .spin-slow { animation: spin 20s linear infinite; }
        @keyframes float {
            0%, 100% { transform: translateY(0) rotate(0deg); }
            50% { transform: translateY(-30px) rotate(15deg); }
        }
        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
    </style>
</head>
<body class="bg-monolith-bg font-display overflow-x-hidden selection:bg-white selection:text-black text-lg">
    
    <!-- Minimalist Crosshair Cursor -->
    <div id="cursor-v" class="cursor-crosshair-v"></div>
    <div id="cursor-h" class="cursor-crosshair-h"></div>
    <div id="cursor-center" class="cursor-dot"></div>

    <!-- Floating Background Cricket Elements -->
    <div class="fixed inset-0 pointer-events-none z-[0] opacity-10 overflow-hidden">
        <!-- Bat -->
        <svg class="absolute top-[10%] left-[10%] w-48 h-48 float-fast text-white" viewBox="0 0 100 100" fill="currentColor">
            <path d="M45,10 L55,10 L55,30 L60,30 L60,95 L40,95 L40,30 L45,30 Z M48,5 L52,5 L52,10 L48,10 Z" />
        </svg>
        <!-- Wicket -->
        <svg class="absolute top-[35%] right-[5%] w-64 h-64 float-slow text-white" viewBox="0 0 100 100" fill="currentColor">
            <rect x="30" y="20" width="8" height="70" rx="4" />
            <rect x="46" y="20" width="8" height="70" rx="4" />
            <rect x="62" y="20" width="8" height="70" rx="4" />
            <rect x="32" y="15" width="16" height="4" rx="2" />
            <rect x="52" y="15" width="16" height="4" rx="2" />
        </svg>
        <!-- Ball -->
        <svg class="absolute bottom-[10%] left-[20%] w-40 h-40 spin-slow text-white" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="4">
            <circle cx="50" cy="50" r="40" />
            <path d="M30,20 Q50,50 30,80 M70,20 Q50,50 70,80" stroke-dasharray="6 4" />
        </svg>
        <!-- Helmet -->
        <svg class="absolute top-[65%] right-[25%] w-56 h-56 float-fast text-white" viewBox="0 0 100 100" fill="none" stroke="currentColor" stroke-width="4">
            <path d="M20,60 A30,30 0 0,1 80,60 L80,75 L20,75 Z" fill="currentColor" opacity="0.3"/>
            <path d="M20,60 A30,30 0 0,1 80,60" />
            <path d="M10,75 L90,75 M25,85 L75,85" stroke-linecap="round" />
        </svg>
    </div>

    <div class="relative z-10">
        <slot />
    </div>

    <script is:inline src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script is:inline>
        AOS.init({ once: true, offset: 50, duration: 1000, easing: 'ease-out-cubic' });
        
        // Custom Crosshair Logic
        const cursorV = document.getElementById('cursor-v');
        const cursorH = document.getElementById('cursor-h');
        const cursorCenter = document.getElementById('cursor-center');
        
        if (window.innerWidth > 768) {
            document.addEventListener('mousemove', (e) => {
                cursorV.style.left = `${e.clientX}px`;
                cursorH.style.top = `${e.clientY}px`;
                cursorCenter.style.left = `${e.clientX}px`;
                cursorCenter.style.top = `${e.clientY}px`;
            });

            document.querySelectorAll('a, button').forEach(el => {
                el.addEventListener('mouseenter', () => {
                    cursorCenter.style.transform = 'translate(-50%, -50%) scale(4)';
                    cursorCenter.style.transition = 'transform 0.3s ease';
                });
                el.addEventListener('mouseleave', () => {
                    cursorCenter.style.transform = 'translate(-50%, -50%) scale(1)';
                });
            });
        }
    </script>
</body>
</html>
