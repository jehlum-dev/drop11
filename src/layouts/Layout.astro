---
import '../styles/global.css';
const {
    title = "Drop 11 — Cricket Club",
    description = "Drop 11 Cricket Club. We are a simple cricket team."
} = Astro.props;
const ogImage = "/og-image.jpg";

// The base path is needed for GitHub Pages
const baseUrl = import.meta.env.BASE_URL;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>

    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, Astro.url)} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={Astro.url} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.url)} />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300..800&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>
<body class="selection:bg-lime selection:text-black">
    <!-- The rug pattern is applied to the body. This panel contains all the actual site content with a black background. -->
    <div class="content-panel">
        <slot />
    </div>

    <script is:inline define:vars={{ baseUrl }}>
        // Random background patterns
        const patterns = [
            'rug-pattern.jpg',
            'patterns/pattern_rug_bright_1783620149317.jpg',
            'patterns/pattern_cricket_grass_1783620639224.jpg',
            'patterns/pattern_cricket_lords_1783620629001.jpg'
        ];
        // Pick a random pattern on every refresh
        const randomPattern = patterns[Math.floor(Math.random() * patterns.length)];
        // Construct the full URL keeping base URL in mind
        const imgUrl = (baseUrl + randomPattern).replace(/\/\//g, '/');
        document.body.style.backgroundImage = `url('${imgUrl}')`;

        // Scroll reveal logic
        const obs = new IntersectionObserver(
            entries => entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('vis'); }),
            { threshold: 0.08, rootMargin: '0px 0px -20px 0px' }
        );
        document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
        document.addEventListener('DOMContentLoaded', () => {
            document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
        });
    </script>
</body>
</html>
