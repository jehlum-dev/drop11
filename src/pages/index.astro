---
import Layout from '../layouts/Layout.astro';
import PlayerCard from '../components/PlayerCard.astro';

const players = [
    { id: 'AX-01', name: 'Z-Xen', role: 'Striker', status: 'Optimal' },
    { id: 'AX-02', name: 'V-Rekt', role: 'Destroyer', status: 'Overcharged' },
    { id: 'AX-03', name: 'Q-Null', role: 'Quantum Spinner', status: 'Stable' },
    { id: 'AX-04', name: 'K-Prime', role: 'Velocity Modulator', status: 'Optimal' },
    { id: 'AX-05', name: 'N-Hex', role: 'Striker', status: 'Calibrating...' },
    { id: 'AX-06', name: 'T-Sync', role: 'Shield Bearer', status: 'Optimal' },
];
---
<Layout title="Alien Strikers | Evolved">
    <nav class="fixed w-full z-50 transition-all duration-500 backdrop-blur-md border-b border-alien-neon/20 bg-alien-bg/50">
        <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
            <a href="#" class="text-2xl font-orbitron font-bold text-transparent bg-clip-text bg-gradient-to-r from-alien-neon to-alien-cyan tracking-[0.2em] glitch" data-text="A-STRIKERS">A-STRIKERS</a>
        </div>
    </nav>

    <header class="min-h-screen flex items-center justify-center relative overflow-hidden pt-20">
        <div class="absolute top-1/4 left-1/4 w-64 h-64 bg-alien-purple/20 blur-[100px] rounded-full mix-blend-screen animate-pulse"></div>
        <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-alien-neon/10 blur-[120px] rounded-full mix-blend-screen animate-pulse" style="animation-delay: 2s;"></div>
        
        <div class="container mx-auto px-6 relative z-10 text-center flex flex-col items-center">
            <div data-aos="fade-down" data-aos-duration="1500" class="inline-block mb-6 px-4 py-1 border border-alien-cyan/50 text-alien-cyan text-xs tracking-[0.5em] uppercase bg-alien-cyan/5 backdrop-blur-sm rounded-full shadow-[0_0_15px_#0ff]">
                System Initialized
            </div>
            <h1 data-aos="zoom-in" data-aos-duration="2000" class="text-5xl md:text-8xl font-orbitron font-black text-white mb-6 uppercase tracking-tighter mix-blend-difference">
                Cricket<br>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-alien-neon via-white to-alien-purple glitch" data-text="EVOLVED">EVOLVED</span>
            </h1>
            <p data-aos="fade-up" data-aos-duration="1500" data-aos-delay="500" class="max-w-2xl text-lg md:text-xl text-alien-neon/80 mb-12">
                We are not of this world. Our precision is algorithmic. Our power is absolute.
            </p>
        </div>
    </header>

    <section id="entities" class="py-32 bg-black/40 border-y border-alien-neon/10">
        <div class="container mx-auto px-6">
            <h2 data-aos="fade-up" class="text-4xl md:text-5xl font-orbitron text-center mb-16 text-white uppercase tracking-[0.3em]">
                Biological <span class="text-alien-neon">Assets</span>
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-7xl mx-auto">
                {players.map((p, index) => (
                    <PlayerCard id={p.id} name={p.name} role={p.role} status={p.status} delay={index * 100} />
                ))}
            </div>
        </div>
    </section>
</Layout>
