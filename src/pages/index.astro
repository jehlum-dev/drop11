---
import Layout from '../layouts/Layout.astro';
import PlayerCard from '../components/PlayerCard.astro';
import InteractiveWicket from '../components/InteractiveWicket.astro';
import RealBall from '../components/RealBall.astro';

const players = [
    { name: 'Talib Mir', imgUrl: '/talib.jpeg' },
    { name: 'Nasir Mir', imgUrl: '/nasir.jpeg' },
    { name: 'Anna Adil', imgUrl: '/adil.jpeg' },
    { name: 'Faizan Mir', imgUrl: '/faizan.jpeg' },
    { name: 'Hazim Mushtaq', imgUrl: '/hazim.jpeg' },
    { name: 'Danish Javid', imgUrl: '' },
    { name: 'Yasir Hameed', imgUrl: '' },
    { name: 'Saqib Lefty', imgUrl: '' },
    { name: 'Basit Peer', imgUrl: '' },
    { name: 'Shahid Pacer', imgUrl: '' }
];
---
<Layout title="DROP 11 | CRICKET">
    <!-- Navbar -->
    <nav class="border-b-4 border-brutal-black bg-brutal-yellow flex flex-col md:flex-row justify-between items-center p-4">
        <div class="text-4xl md:text-5xl tracking-tighter">DROP 11</div>
        <div class="font-mono text-sm tracking-widest flex gap-8 mt-4 md:mt-0 font-bold">
            <a href="#matches" class="hover:bg-brutal-black hover:text-brutal-yellow px-3 py-2 border-4 border-transparent hover:border-brutal-black transition-colors">MATCHES</a>
            <a href="#awards" class="hover:bg-brutal-black hover:text-brutal-yellow px-3 py-2 border-4 border-transparent hover:border-brutal-black transition-colors">AWARDS</a>
            <a href="#roster" class="hover:bg-brutal-black hover:text-brutal-yellow px-3 py-2 border-4 border-transparent hover:border-brutal-black transition-colors">SQUAD</a>
        </div>
    </nav>

    <!-- Hero Section -->
    <header class="border-b-4 border-brutal-black grid grid-cols-1 lg:grid-cols-2 bg-brutal-white relative overflow-hidden">
        <!-- Text Side -->
        <div class="p-8 md:p-16 border-b-4 lg:border-b-0 lg:border-r-4 border-brutal-black flex flex-col justify-center relative">
            <h1 class="text-7xl md:text-[8rem] xl:text-[12rem] leading-[0.8] tracking-tighter mb-12 relative z-10 drop-shadow-[8px_8px_0_rgba(0,0,0,1)]">
                DROP 11
            </h1>
            <div class="bg-brutal-black text-brutal-white p-6 md:p-8 shadow-brutal-yellow border-heavy max-w-xl relative z-10 transform hover:-translate-y-2 transition-transform duration-300">
                <p class="font-mono text-lg md:text-2xl uppercase tracking-widest font-bold leading-relaxed">
                    We are a simple cricket team. We focus on pure talent, aggressive gameplay, and dominating the pitch. Welcome to the club.
                </p>
            </div>
        </div>
        
        <!-- Interactive Ball Side -->
        <div class="p-12 md:p-24 flex items-center justify-center relative min-h-[500px]">
            <div class="absolute top-4 left-4 font-mono text-sm font-bold bg-brutal-white border-2 border-brutal-black px-2 z-20">[OBJ: BALL]</div>
            <div class="relative z-30">
                <RealBall />
            </div>
        </div>
    </header>

    <!-- Roster -->
    <section id="roster" class="p-8 md:p-16 border-b-4 border-brutal-black">
        <h2 class="text-[4rem] md:text-[8rem] lg:text-[10rem] tracking-tighter leading-[0.8] mb-12 border-b-8 border-brutal-black pb-6 uppercase">
            THE SQUAD
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-12">
            {players.map((p) => (
                <PlayerCard name={p.name} imgUrl={p.imgUrl} />
            ))}
        </div>
    </section>

    <!-- Matches Section -->
    <section id="matches" class="p-8 md:p-16 border-b-4 border-brutal-black bg-brutal-bg">
        <h2 class="text-[4rem] md:text-[8rem] tracking-tighter leading-none mb-12 border-b-8 border-brutal-black pb-6">MATCHES</h2>
        <div class="flex flex-col gap-6">
            
            <!-- Match Row 1 -->
            <div class="group border-4 border-brutal-black bg-brutal-white shadow-brutal flex justify-between items-center p-6 md:p-8 cursor-pointer hover:bg-brutal-black transition-colors overflow-hidden relative">
                <!-- Background sweeping animation -->
                <div class="absolute inset-0 w-0 bg-brutal-yellow group-hover:w-full transition-all duration-500 ease-out z-0"></div>
                
                <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between w-full gap-4 md:gap-12">
                    <span class="font-mono text-2xl md:text-3xl font-bold w-48 transform group-hover:translate-x-6 transition-transform duration-300 group-hover:text-brutal-black">OCT 12</span>
                    <span class="text-4xl md:text-6xl tracking-tighter flex-grow transform group-hover:translate-x-12 transition-transform duration-300 delay-75 group-hover:text-brutal-black">VS. RED TITANS</span>
                    <span class="font-mono text-3xl font-bold border-4 border-brutal-black px-6 py-2 transform group-hover:-translate-x-6 transition-transform duration-300 delay-150 bg-brutal-yellow text-brutal-black shadow-[4px_4px_0_0_#050505]">WIN</span>
                </div>
            </div>

            <!-- Match Row 2 -->
            <div class="group border-4 border-brutal-black bg-brutal-white shadow-brutal flex justify-between items-center p-6 md:p-8 cursor-pointer hover:bg-brutal-black transition-colors overflow-hidden relative">
                <div class="absolute inset-0 w-0 bg-brutal-yellow group-hover:w-full transition-all duration-500 ease-out z-0"></div>
                <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between w-full gap-4 md:gap-12">
                    <span class="font-mono text-2xl md:text-3xl font-bold w-48 transform group-hover:translate-x-6 transition-transform duration-300 group-hover:text-brutal-black">NOV 05</span>
                    <span class="text-4xl md:text-6xl tracking-tighter flex-grow transform group-hover:translate-x-12 transition-transform duration-300 delay-75 group-hover:text-brutal-black">VS. GREEN EAGLES</span>
                    <span class="font-mono text-3xl font-bold border-4 border-brutal-black px-6 py-2 transform group-hover:-translate-x-6 transition-transform duration-300 delay-150 bg-brutal-white text-brutal-black shadow-[4px_4px_0_0_#050505]">UPCOMING</span>
                </div>
            </div>

            <!-- Match Row 3 -->
            <div class="group border-4 border-brutal-black bg-brutal-white shadow-brutal flex justify-between items-center p-6 md:p-8 cursor-pointer hover:bg-brutal-black transition-colors overflow-hidden relative">
                <div class="absolute inset-0 w-0 bg-brutal-yellow group-hover:w-full transition-all duration-500 ease-out z-0"></div>
                <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between w-full gap-4 md:gap-12">
                    <span class="font-mono text-2xl md:text-3xl font-bold w-48 transform group-hover:translate-x-6 transition-transform duration-300 group-hover:text-brutal-black">DEC 20</span>
                    <span class="text-4xl md:text-6xl tracking-tighter flex-grow transform group-hover:translate-x-12 transition-transform duration-300 delay-75 group-hover:text-brutal-black">VS. VOID WALKERS</span>
                    <span class="font-mono text-3xl font-bold border-4 border-brutal-black px-6 py-2 transform group-hover:-translate-x-6 transition-transform duration-300 delay-150 bg-brutal-white text-brutal-black shadow-[4px_4px_0_0_#050505]">UPCOMING</span>
                </div>
            </div>
            
        </div>
    </section>

    <!-- Awards Section -->
    <section id="awards" class="p-8 md:p-16 border-b-4 border-brutal-black bg-brutal-black text-brutal-white">
        <h2 class="text-[4rem] md:text-[8rem] tracking-tighter leading-none mb-12 border-b-8 border-brutal-yellow pb-6 text-brutal-yellow">AWARDS</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            
            <!-- Award Card 1 -->
            <div class="border-4 border-brutal-white bg-brutal-black hover:bg-brutal-white hover:text-brutal-black transition-colors duration-300 group flex flex-col cursor-pointer">
                <div class="h-48 border-b-4 border-brutal-white group-hover:border-brutal-black overflow-hidden relative">
                    <img src="https://images.unsplash.com/photo-1577223625816-7546f13df25d?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="Championship Cup" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-300" />
                </div>
                <div class="p-6">
                    <h3 class="text-3xl md:text-5xl font-black tracking-tighter mb-2">CHAMPIONSHIP CUP</h3>
                    <p class="font-mono text-lg uppercase font-bold text-brutal-yellow group-hover:text-brutal-black">📍 LONDON, UK // 2025</p>
                </div>
            </div>

            <!-- Award Card 2 -->
            <div class="border-4 border-brutal-white bg-brutal-black hover:bg-brutal-white hover:text-brutal-black transition-colors duration-300 group flex flex-col cursor-pointer">
                <div class="h-48 border-b-4 border-brutal-white group-hover:border-brutal-black overflow-hidden relative">
                    <img src="https://images.unsplash.com/photo-1526328828355-69b01701ca6a?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80" alt="League Trophy" class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-300" />
                </div>
                <div class="p-6">
                    <h3 class="text-3xl md:text-5xl font-black tracking-tighter mb-2">UNDEFEATED SEASON</h3>
                    <p class="font-mono text-lg uppercase font-bold text-brutal-yellow group-hover:text-brutal-black">📍 MELBOURNE, AUS // 2024</p>
                </div>
            </div>
            
        </div>
    </section>

    <!-- Footer with Wicket -->
    <footer class="bg-brutal-yellow text-brutal-black p-12 md:p-24 flex flex-col items-center border-t-8 border-brutal-black">
        <div class="mb-12 relative">
            <InteractiveWicket />
            <div class="absolute -top-6 -right-6 font-mono font-bold text-xs bg-brutal-white border-2 border-brutal-black px-2 py-1 shadow-[2px_2px_0_0_#050505]">TAP TO BREAK</div>
        </div>
        <h1 class="text-6xl md:text-[10rem] tracking-tighter leading-none mt-8">DROP 11</h1>
    </footer>
</Layout>
