---
import Layout from '../layouts/Layout.astro';
import PlayerCard from '../components/PlayerCard.astro';
import InteractiveWicket from '../components/InteractiveWicket.astro';

const players = [
    { id: 'BAT-01', name: 'Virat Singh', role: 'Top Order Batsman', jersey: '18', imgUrl: 'https://images.unsplash.com/photo-1599566150163-29194dcaad36?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' },
    { id: 'BAT-02', name: 'Rahul Patel', role: 'Opening Batsman', jersey: '45', imgUrl: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' },
    { id: 'BWL-01', name: 'David Trent', role: 'Pace Bowler', jersey: '33', imgUrl: 'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' },
    { id: 'WKT-01', name: 'MS Kumar', role: 'Wicket-Keeper', jersey: '07', imgUrl: 'https://images.unsplash.com/photo-1527980965255-d3b416303d12?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' },
    { id: 'BWL-02', name: 'Sam Rashid', role: 'Spin Bowler', jersey: '19', imgUrl: 'https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' },
    { id: 'ALL-01', name: 'Ben Stokes', role: 'All-Rounder', jersey: '55', imgUrl: 'https://images.unsplash.com/photo-1543610892-0b1f7e6d8ac1?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' },
];
---
<Layout title="DROP11 | CRICKET">
    <nav class="fixed w-full z-50 p-6 bg-monolith-bg/90 backdrop-blur-md shadow-lg border-b border-monolith-border">
        <div class="flex justify-between items-center max-w-7xl mx-auto">
            <a href="#" class="text-xl md:text-3xl font-display font-black tracking-widest uppercase text-white hover:text-cricket-red transition-colors flex items-center gap-4">
                <div class="w-8 h-8 bg-cricket-red rounded-full"></div>
                DROP11
            </a>
            <div class="flex gap-8 font-mono text-sm tracking-[0.2em] uppercase text-monolith-text hidden md:flex">
                <a href="#club" class="hover:text-white transition-colors">The Club</a>
                <a href="#squad" class="hover:text-white transition-colors">First XI</a>
                <a href="#fixtures" class="hover:text-white transition-colors">Fixtures</a>
            </div>
        </div>
    </nav>

    <header class="min-h-screen flex flex-col items-center justify-center relative px-6 mt-12 overflow-hidden">
        
        <!-- Two isolated cricket balls fading between each other continuously -->
        <div class="absolute inset-0 flex items-center justify-center pointer-events-none z-10 mt-20">
            <div class="relative w-full max-w-xs md:max-w-xl animate-levitate">
                <img src="/red_ball.jpg" alt="Realistic Red Cricket Ball" 
                     class="absolute inset-0 w-full animate-fade-swap clip-circle shadow-[0_0_100px_rgba(163,0,0,0.6)]">
                <img src="/white_ball.jpg" alt="Realistic White Cricket Ball" 
                     class="w-full clip-circle shadow-[0_0_100px_rgba(255,255,255,0.4)]">
            </div>
        </div>
        
        <div class="relative z-20 w-full max-w-5xl mt-auto pb-20 pointer-events-none">
            <h1 class="text-7xl md:text-9xl font-black tracking-widest uppercase text-center mb-8 text-white drop-shadow-2xl">
                D R O P 1 1
            </h1>
            <p class="font-mono text-lg md:text-2xl tracking-[0.1em] text-center text-white max-w-2xl mx-auto leading-relaxed bg-black/60 backdrop-blur-md p-6 rounded-lg border-2 border-monolith-border shadow-2xl">
                Raw Power. <span class="text-cricket-red font-bold">Real Cricket.</span><br>
                Welcome to the pitch.
            </p>
        </div>
    </header>

    <section id="club" class="py-32 bg-monolith-surface border-y-4 border-monolith-border relative z-30">
        <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-20 items-center">
            <div data-aos="fade-right">
                <h2 class="text-5xl font-black tracking-widest uppercase mb-8 text-white flex items-center gap-6">
                    The Club
                </h2>
                <p class="font-mono text-xl tracking-wider leading-relaxed text-monolith-text mb-12">
                    Forget the minimal abstract art. This is real cricket. Grass stains, shattered stumps, and screaming fastballs. We play to dominate.
                </p>
                <div class="grid grid-cols-2 gap-8">
                    <div class="bg-monolith-bg p-6 rounded border-l-4 border-cricket-red">
                        <div class="font-mono text-sm tracking-widest uppercase text-monolith-muted mb-2">Matches</div>
                        <div class="text-5xl font-black text-white">142</div>
                    </div>
                    <div class="bg-monolith-bg p-6 rounded border-l-4 border-white">
                        <div class="font-mono text-sm tracking-widest uppercase text-monolith-muted mb-2">Win Rate</div>
                        <div class="text-5xl font-black text-white">89.9%</div>
                    </div>
                </div>
            </div>
            
            <div data-aos="zoom-in" class="flex flex-col items-center justify-center p-12 bg-black/40 rounded-3xl border border-monolith-border shadow-2xl">
                <h3 class="font-mono text-lg tracking-widest text-monolith-muted mb-16 uppercase text-center">Tap to shatter</h3>
                <InteractiveWicket />
            </div>
        </div>
    </section>

    <section id="squad" class="py-32 max-w-7xl mx-auto px-6">
        <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-8 mb-20 border-b-4 border-white pb-6" data-aos="fade-right">
            <h2 class="text-5xl font-black tracking-[0.2em] uppercase text-white">
                The First XI
            </h2>
            <div class="font-mono text-sm tracking-widest uppercase text-monolith-muted bg-monolith-surface px-4 py-2 rounded">
                Tap cards for 3D Pop
            </div>
        </div>
        
        <div class="flex flex-col gap-12">
            {players.map((p, index) => (
                <PlayerCard id={p.id} name={p.name} role={p.role} jersey={p.jersey} imgUrl={p.imgUrl} delay={index * 100} />
            ))}
        </div>
    </section>

    <footer id="fixtures" class="py-32 border-t-8 border-cricket-red text-center bg-black">
        <div class="max-w-5xl mx-auto px-6">
            <h2 data-aos="fade-up" class="text-5xl font-black tracking-[0.2em] uppercase mb-16 text-white">Upcoming Fixtures</h2>
            
            <div class="space-y-6">
                <div class="flex justify-between items-center bg-monolith-surface/80 hover:bg-monolith-surface transition-colors p-8 rounded-xl border-l-8 border-white cursor-pointer shadow-lg transform hover:scale-105 duration-300">
                    <span class="font-mono text-lg md:text-xl text-monolith-muted tracking-widest">Aug 15 @ 14:00</span>
                    <span class="text-xl md:text-2xl font-black text-white uppercase tracking-widest">VS Red Titans</span>
                </div>
                <div class="flex justify-between items-center bg-monolith-surface/80 hover:bg-monolith-surface transition-colors p-8 rounded-xl border-l-8 border-white cursor-pointer shadow-lg transform hover:scale-105 duration-300">
                    <span class="font-mono text-lg md:text-xl text-monolith-muted tracking-widest">Aug 22 @ 10:30</span>
                    <span class="text-xl md:text-2xl font-black text-white uppercase tracking-widest">VS Green Eagles</span>
                </div>
            </div>
            
            <div class="mt-32 font-mono text-lg tracking-widest uppercase text-monolith-muted flex items-center justify-center gap-4">
                <div class="w-4 h-4 bg-cricket-red rounded-full"></div>
                &copy; 2026 // DROP11 CRICKET CLUB
            </div>
        </div>
    </footer>
</Layout>
