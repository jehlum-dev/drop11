---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/HeroSection.astro';
import RosterSection from '../components/RosterSection.astro';
import FixturesSection from '../components/FixturesSection.astro';
import HonoursSection from '../components/HonoursSection.astro';
import RealBall from '../components/RealBall.astro';
import Navbar from '../components/Navbar.astro';
---
<Layout title="Drop 11 | Perfect Edition">
    
    <!-- Elegant Scroll Progress Sides -->
    <div class="fixed top-0 left-0 w-1 h-full bg-black/5 z-[100] pointer-events-none">
        <div id="scroll-progress-left" class="w-full bg-brand-accent transition-all duration-100 ease-out" style="height: 0%;"></div>
    </div>
    <div class="fixed top-0 right-0 w-1 h-full bg-black/5 z-[100] pointer-events-none flex flex-col justify-end">
        <div id="scroll-progress-right" class="w-full bg-brand-accent transition-all duration-100 ease-out" style="height: 0%;"></div>
    </div>
    
    <!-- Physics Ball -->
    <RealBall />

    <!-- Navigation -->
    <Navbar />

    <main class="pt-20">
        <HeroSection />
        <RosterSection />
        <FixturesSection />
        <HonoursSection />
    </main>

    <footer class="py-12 border-t border-black/10 bg-brand-text text-brand-bg text-center">
        <p class="text-xs font-bold uppercase tracking-[0.2em] opacity-50">© 2026 Drop 11 Cricket Club</p>
    </footer>

    <script is:inline>
        // Update Scroll Progress Bars
        window.addEventListener('scroll', () => {
            const scrollTotal = document.documentElement.scrollHeight - window.innerHeight;
            const scrollFraction = Math.max(0, Math.min(1, window.scrollY / scrollTotal));
            const percentage = scrollFraction * 100;
            
            document.getElementById('scroll-progress-left').style.height = `${percentage}%`;
            document.getElementById('scroll-progress-right').style.height = `${percentage}%`;
        });
    </script>
</Layout>
