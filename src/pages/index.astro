---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/HeroSection.astro';
import RosterSection from '../components/RosterSection.astro';
import FixturesSection from '../components/FixturesSection.astro';
import HonoursSection from '../components/HonoursSection.astro';
import RealBall from '../components/RealBall.astro';
import Navbar from '../components/Navbar.astro';
import SideBorders from '../components/SideBorders.astro';
---
<Layout title="Drop 11 — Cricket Club">

    <!-- Decorative side borders -->
    <SideBorders />

    <!-- Physics Ball -->
    <RealBall />

    <!-- Navigation -->
    <Navbar />

    <!-- Main Content -->
    <main>
        <HeroSection />
        <RosterSection />
        <FixturesSection />
        <HonoursSection />
    </main>

    <!-- Footer -->
    <footer class="border-t border-stroke">
        <div class="max-w-[1200px] mx-auto px-5 sm:px-8 md:px-10 lg:px-12 py-10 md:py-14">
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6 mb-8">
                <div class="flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full bg-lime"></span>
                    <span class="font-display text-lg font-bold text-txt">DROP <span class="text-lime">11</span></span>
                </div>
                <div class="flex items-center gap-6">
                    <a href="#squad" class="text-[11px] font-semibold uppercase tracking-[0.14em] text-txt-2 hover:text-txt transition-colors">Squad</a>
                    <a href="#fixtures" class="text-[11px] font-semibold uppercase tracking-[0.14em] text-txt-2 hover:text-txt transition-colors">Fixtures</a>
                    <a href="#honours" class="text-[11px] font-semibold uppercase tracking-[0.14em] text-txt-2 hover:text-txt transition-colors">Honours</a>
                </div>
            </div>
            <div class="h-px bg-stroke mb-6"></div>
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-2">
                <p class="text-[10px] font-medium tracking-[0.15em] uppercase text-txt-3">© 2026 Drop 11 Cricket Club</p>
                <p class="text-[10px] font-medium tracking-[0.15em] uppercase text-txt-3">Langate, Kashmir</p>
            </div>
        </div>
    </footer>
</Layout>
