---
import Layout from '../layouts/Layout.astro';
import PlayerCard from '../components/PlayerCard.astro';
import InteractiveWicket from '../components/InteractiveWicket.astro';
import RealBall from '../components/RealBall.astro';

const players = [
    { id: 'BAT-01', name: 'Virat Singh', role: 'Top Batsman', jersey: '18', imgUrl: 'https://images.unsplash.com/photo-1599566150163-29194dcaad36?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' },
    { id: 'BAT-02', name: 'Rahul Patel', role: 'Opening Bat', jersey: '45', imgUrl: 'https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' },
    { id: 'BWL-01', name: 'David Trent', role: 'Pace Bowler', jersey: '33', imgUrl: 'https://images.unsplash.com/photo-1500648767791-00dcc994a43e?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' },
    { id: 'WKT-01', name: 'MS Kumar', role: 'Wicket-Keep', jersey: '07', imgUrl: 'https://images.unsplash.com/photo-1527980965255-d3b416303d12?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' },
    { id: 'BWL-02', name: 'Sam Rashid', role: 'Spin Bowler', jersey: '19', imgUrl: 'https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' },
    { id: 'ALL-01', name: 'Ben Stokes', role: 'All-Rounder', jersey: '55', imgUrl: 'https://images.unsplash.com/photo-1543610892-0b1f7e6d8ac1?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' },
];
---
<Layout title="URCC | CRICKET">
    <!-- Navbar -->
    <nav class="border-b-4 border-brutal-black bg-brutal-yellow flex flex-col md:flex-row justify-between items-center p-4">
        <div class="text-4xl md:text-5xl tracking-tighter">DROP11 CRICKET CLUB</div>
        <div class="font-mono text-sm tracking-widest flex gap-8 mt-4 md:mt-0 font-bold">
            <a href="#roster" class="hover:bg-brutal-black hover:text-brutal-yellow px-3 py-2 border-4 border-transparent hover:border-brutal-black transition-colors">ROSTER</a>
            <a href="#fixtures" class="hover:bg-brutal-black hover:text-brutal-yellow px-3 py-2 border-4 border-transparent hover:border-brutal-black transition-colors">FIXTURES</a>
        </div>
    </nav>

    <!-- Hero Section -->
    <header class="border-b-4 border-brutal-black grid grid-cols-1 lg:grid-cols-2">
        <!-- Text Side -->
        <div class="p-8 md:p-16 border-b-4 lg:border-b-0 lg:border-r-4 border-brutal-black flex flex-col justify-center relative overflow-hidden">
            <div class="absolute -top-10 -left-10 text-[20rem] text-black/5 select-none z-0">11</div>
            
            <h1 class="text-7xl md:text-[8rem] xl:text-[10rem] leading-[0.8] tracking-tighter mb-8 relative z-10">
                RAW.<br>BRUTAL.<br>CRICKET.
            </h1>
            <div class="bg-brutal-black text-brutal-white p-6 md:p-8 shadow-brutal-yellow border-heavy max-w-lg relative z-10">
                <p class="font-mono text-base md:text-xl lowercase tracking-normal">
                    [sys_log]: ignoring tradition. ignoring elegance. we play to completely dismantle the opposition.
                </p>
            </div>
        </div>
        
        <!-- Interactive Ball Side -->
        <div class="p-12 md:p-24 flex items-center justify-center relative min-h-[500px]">
            <!-- Grid coordinate decorations -->
            <div class="absolute top-4 left-4 font-mono text-sm font-bold bg-brutal-white border-2 border-brutal-black px-2">[GRID: 01A]</div>
            <div class="absolute bottom-4 right-4 font-mono text-sm font-bold bg-brutal-white border-2 border-brutal-black px-2">[COORDS: 51.50]</div>
            
            <RealBall />
        </div>
    </header>

    <!-- Data / Wicket Section -->
    <section class="border-b-4 border-brutal-black grid grid-cols-1 lg:grid-cols-3">
        <div class="col-span-1 border-b-4 lg:border-b-0 lg:border-r-4 border-brutal-black p-8 md:p-12 bg-brutal-yellow">
            <h2 class="text-6xl md:text-7xl tracking-tighter mb-8">CLUB DATA</h2>
            <ul class="font-mono space-y-4 text-xl md:text-2xl border-t-4 border-brutal-black pt-6 font-bold">
                <li class="flex justify-between border-b-4 border-brutal-black pb-4"><span>MATCHES</span> <span>142</span></li>
                <li class="flex justify-between border-b-4 border-brutal-black pb-4"><span>WIN RATE</span> <span>89.9%</span></li>
                <li class="flex justify-between border-b-4 border-brutal-black pb-4"><span>STATUS</span> <span>HOSTILE</span></li>
            </ul>
        </div>
        
        <div class="col-span-1 lg:col-span-2 p-12 md:p-24 flex flex-col justify-center items-center relative overflow-hidden bg-white">
            <div class="absolute top-4 left-4 font-mono text-sm font-bold bg-brutal-black text-white px-3 py-1 shadow-brutal-yellow z-20">TAP TO DESTROY</div>
            <!-- Huge background text -->
            <div class="absolute inset-0 flex items-center justify-center text-[10rem] md:text-[15rem] font-black text-black/5 select-none pointer-events-none tracking-tighter whitespace-nowrap overflow-hidden">
                WICKET
            </div>
            <InteractiveWicket />
        </div>
    </section>

    <!-- Roster -->
    <section id="roster" class="p-8 md:p-16 border-b-4 border-brutal-black">
        <h2 class="text-[5rem] md:text-[8rem] lg:text-[10rem] tracking-tighter leading-[0.8] mb-12 border-b-8 border-brutal-black pb-6 uppercase">
            THE SQUAD
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 md:gap-12">
            {players.map((p, index) => (
                <PlayerCard id={p.id} name={p.name} role={p.role} jersey={p.jersey} imgUrl={p.imgUrl} index={index + 1} />
            ))}
        </div>
    </section>

    <footer id="fixtures" class="bg-brutal-black text-brutal-yellow p-12 md:p-24 flex flex-col items-center border-t-8 border-brutal-yellow">
        <h1 class="text-8xl md:text-[12rem] tracking-tighter mb-8 leading-none">DROP11</h1>
        <div class="w-full max-w-4xl border-4 border-brutal-yellow p-8 mb-12">
            <h3 class="text-5xl tracking-tighter mb-8 text-white">FIXTURES</h3>
            <ul class="font-mono text-xl space-y-4">
                <li class="flex justify-between border-b-2 border-brutal-yellow pb-2 hover:bg-brutal-yellow hover:text-brutal-black cursor-pointer px-2 transition-colors"><span>AUG 15</span> <span>RED TITANS</span></li>
                <li class="flex justify-between border-b-2 border-brutal-yellow pb-2 hover:bg-brutal-yellow hover:text-brutal-black cursor-pointer px-2 transition-colors"><span>AUG 22</span> <span>GREEN EAGLES</span></li>
            </ul>
        </div>
        <div class="font-mono text-sm md:text-base uppercase text-white">End of document // [SYS.OK] // 2026</div>
    </footer>
</Layout>
