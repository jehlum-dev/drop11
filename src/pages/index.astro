---
import Layout from '../layouts/Layout.astro';
import HeroSection from '../components/HeroSection.astro';
import RosterSection from '../components/RosterSection.astro';
import FixturesSection from '../components/FixturesSection.astro';
import HonoursSection from '../components/HonoursSection.astro';
import RealBall from '../components/RealBall.astro';
import Navbar from '../components/Navbar.astro';
---
<Layout title="Drop 11 | Perfect Edition">
    
    <!-- Vibrant Side Glows (Strictly on sides, not inside) -->
    <div class="fixed top-0 left-0 w-12 md:w-24 h-full bg-gradient-to-r from-[#FF007F] via-[#FF007F]/40 to-transparent opacity-30 blur-2xl z-[-1] pointer-events-none"></div>
    <div class="fixed top-0 right-0 w-12 md:w-24 h-full bg-gradient-to-l from-[#00F0FF] via-[#00F0FF]/40 to-transparent opacity-30 blur-2xl z-[-1] pointer-events-none"></div>
    
    <!-- Physics Ball -->
    <RealBall />

    <!-- Navigation -->
    <Navbar />

    <main class="pt-20">
        <HeroSection />
        <RosterSection />
        <FixturesSection />
        <HonoursSection />
    </main>

    <footer class="py-12 border-t border-black/10 bg-brand-text text-brand-bg text-center">
        <p class="text-xs font-bold uppercase tracking-[0.2em] opacity-50">© 2026 Drop 11 Cricket Club</p>
    </footer>

</Layout>
