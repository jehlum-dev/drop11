---
import Layout from '../layouts/Layout.astro';
import PlayerCard from '../components/PlayerCard.astro';
import RealBall from '../components/RealBall.astro';

import players from '../data/players.json';
import matches from '../data/matches.json';
import awards from '../data/awards.json';
---
<Layout title="Drop 11">
    
    <!-- Ultra-clean Minimalist Navbar -->
    <nav class="fixed top-0 w-full z-50 bg-editorial-bg/90 backdrop-blur-sm border-b border-editorial-border transition-all">
        <div class="max-w-7xl mx-auto px-6 md:px-12">
            <div class="flex justify-between h-20 items-center">
                <div class="flex items-center gap-4">
                    <span class="font-sans font-bold text-xl tracking-tight text-editorial-text">Drop 11.</span>
                </div>
                <div class="hidden md:flex space-x-8">
                    <a href="#roster" class="text-sm font-medium text-editorial-muted hover:text-editorial-text transition-colors">Squad</a>
                    <a href="#fixtures" class="text-sm font-medium text-editorial-muted hover:text-editorial-text transition-colors">Fixtures</a>
                    <a href="#honours" class="text-sm font-medium text-editorial-muted hover:text-editorial-text transition-colors">Honours</a>
                </div>
            </div>
        </div>
    </nav>
    
    <!-- Ambient Background Elements -->
    <RealBall />

    <!-- Hero Section -->
    <header class="pt-32 pb-24 md:pt-48 md:pb-32 border-b border-editorial-border relative">
        <div class="max-w-7xl mx-auto px-6 md:px-12">
            
            <div class="max-w-3xl">
                <h1 class="text-2xl md:text4xl lg:text-5xl font-serif italic font-medium tracking-tight leading-tight text-editorial-text mb-8">
                    "koī mere dil se pūchhe tire tīr-e-nīm-kash ko<br>
                    ye ḳhalish kahāñ se hotī jo jigar ke paar hotā"
                </h1>
                
                <p class="text-lg md:text-xl text-editorial-muted max-w-lg font-normal leading-relaxed mb-10">
                    We are a simple cricket team.
                </p>
                
                <div>
                    <a href="#roster" class="inline-block border border-editorial-border bg-editorial-surface hover:bg-editorial-text hover:text-white px-8 py-4 rounded-full text-sm font-medium transition-colors duration-300">
                        View the Roster
                    </a>
                </div>
            </div>
            
        </div>
    </header>

    <!-- Roster Section -->
    <section id="roster" class="py-24 md:py-32 border-b border-editorial-border">
        <div class="max-w-7xl mx-auto px-6 md:px-12">
            <div class="mb-16 md:mb-24 flex justify-between items-end">
                <h2 class="text-4xl md:text-6xl font-semibold tracking-tighter">The Squad</h2>
                <span class="text-editorial-muted text-sm hidden md:block">Season 2026/27</span>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-16">
                {players.map((p) => (
                    <PlayerCard name={p.name} imgUrl={p.imgUrl} />
                ))}
            </div>
        </div>
    </section>

    <!-- Fixtures Section -->
    <section id="fixtures" class="py-24 md:py-32 border-b border-editorial-border bg-editorial-surface">
        <div class="max-w-7xl mx-auto px-6 md:px-12">
            <div class="mb-16 md:mb-24">
                <h2 class="text-4xl md:text-6xl font-semibold tracking-tighter">Fixtures</h2>
            </div>
            
            <div class="flex flex-col border-t border-editorial-border">
                {matches.map((m) => (
                    <div class="group flex flex-col md:flex-row justify-between items-start md:items-center py-8 border-b border-editorial-border hover:bg-editorial-bg transition-colors duration-300 px-4 -mx-4 rounded-lg cursor-pointer">
                        <div class="w-full md:w-1/4 mb-4 md:mb-0">
                            <span class="text-sm font-medium text-editorial-muted">{m.date}</span>
                        </div>
                        <div class="w-full md:w-1/2 mb-4 md:mb-0">
                            <h3 class="text-2xl md:text-4xl font-medium tracking-tight group-hover:translate-x-2 transition-transform duration-300">
                                vs {m.opponent}
                            </h3>
                        </div>
                        <div class="w-full md:w-1/4 text-left md:text-right">
                            <span class={`inline-block px-4 py-1.5 rounded-full text-xs font-medium tracking-wide ${m.status === 'WIN' ? 'bg-editorial-text text-white' : 'border border-editorial-border text-editorial-muted'}`}>
                                {m.status}
                            </span>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Honours Section -->
    <section id="honours" class="py-24 md:py-32">
        <div class="max-w-7xl mx-auto px-6 md:px-12">
            <div class="mb-16 md:mb-24">
                <h2 class="text-4xl md:text-6xl font-semibold tracking-tighter">Honours</h2>
            </div>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
                {awards.map((a) => (
                    <div class="group cursor-pointer">
                        <div class="aspect-[4/3] rounded-sm overflow-hidden mb-6 bg-editorial-surface">
                            <img src={a.imgUrl} alt={a.title} class="w-full h-full object-cover grayscale opacity-90 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700 ease-out group-hover:scale-[1.02]" />
                        </div>
                        <div>
                            <h3 class="text-2xl md:text-3xl font-medium tracking-tight mb-2">{a.title}</h3>
                            <p class="text-editorial-muted text-sm">{a.subtext}</p>
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="py-12 bg-editorial-surface">
        <div class="max-w-7xl mx-auto px-6 md:px-12 flex flex-col md:flex-row justify-between items-center gap-4">
            <span class="font-sans font-bold text-lg tracking-tight text-editorial-text">Drop 11.</span>
            <p class="text-xs text-editorial-muted font-medium">© 2026 Drop 11 Cricket Club.</p>
        </div>
    </footer>
</Layout>
