---
---
<nav class="fixed top-0 left-0 right-0 z-[100] bg-brand-bg/95 backdrop-blur-md border-b border-black/5 transition-all">
    <div class="max-w-7xl mx-auto px-6 md:px-12 flex justify-between h-20 items-center">
        <!-- Logo -->
        <a href="#" class="font-serif italic font-bold text-2xl tracking-tighter text-brand-text hover:opacity-80 transition-opacity">
            Drop 11
        </a>
        
        <!-- Desktop Links -->
        <div class="hidden md:flex items-center space-x-12">
            <a href="#roster" class="text-xs font-bold uppercase tracking-widest text-brand-text hover:text-brand-accent transition-colors duration-300 ease-apple">Squad</a>
            <a href="#fixtures" class="text-xs font-bold uppercase tracking-widest text-brand-text hover:text-brand-accent transition-colors duration-300 ease-apple">Fixtures</a>
            <a href="#honours" class="text-xs font-bold uppercase tracking-widest text-brand-text hover:text-brand-accent transition-colors duration-300 ease-apple">Honours</a>
        </div>
        
        <!-- Mobile Menu Button (Hamburger) -->
        <div class="md:hidden flex items-center">
            <button id="mobile-menu-btn" class="text-brand-text focus:outline-none p-2" aria-label="Toggle menu">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path id="menu-icon-path" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                </svg>
            </button>
        </div>
    </div>

    <!-- Mobile Dropdown Menu -->
    <div id="mobile-menu" class="md:hidden hidden bg-brand-bg border-b border-black/5 absolute w-full left-0 shadow-2xl transition-all">
        <div class="px-6 py-8 flex flex-col space-y-8 text-center">
            <a href="#roster" class="mobile-link text-sm font-bold uppercase tracking-[0.2em] text-brand-text">Squad</a>
            <a href="#fixtures" class="mobile-link text-sm font-bold uppercase tracking-[0.2em] text-brand-text">Fixtures</a>
            <a href="#honours" class="mobile-link text-sm font-bold uppercase tracking-[0.2em] text-brand-text">Honours</a>
        </div>
    </div>
</nav>

<script is:inline>
    const btn = document.getElementById('mobile-menu-btn');
    const menu = document.getElementById('mobile-menu');
    const links = document.querySelectorAll('.mobile-link');
    const path = document.getElementById('menu-icon-path');
    
    let isOpen = false;

    function toggleMenu() {
        isOpen = !isOpen;
        if (isOpen) {
            menu.classList.remove('hidden');
            path.setAttribute('d', 'M6 18L18 6M6 6l12 12'); // X icon
        } else {
            menu.classList.add('hidden');
            path.setAttribute('d', 'M4 6h16M4 12h16M4 18h16'); // Hamburger icon
        }
    }

    if (btn && menu) {
        btn.addEventListener('click', toggleMenu);
        links.forEach(link => {
            link.addEventListener('click', () => {
                if(isOpen) toggleMenu();
            });
        });
    }
</script>
