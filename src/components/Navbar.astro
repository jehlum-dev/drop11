---
---
<nav id="site-nav" class="sticky top-0 z-[90] transition-all duration-300 border-b border-transparent">
    <div class="w-full px-5 sm:px-8 md:px-10 lg:px-12">
        <div class="flex items-center justify-between h-16 md:h-[70px]">

            <!-- Logo -->
            <a href="#" class="flex items-center gap-2 shrink-0 group">
                <span class="w-3 h-3 rounded-full bg-lime group-hover:shadow-[0_0_12px_rgba(204,255,0,0.6)] transition-shadow duration-300"></span>
                <span class="font-display text-lg md:text-xl font-bold text-txt tracking-tight">DROP <span class="text-lime">11</span></span>
            </a>

            <!-- Desktop -->
            <div class="hidden md:flex items-center gap-1">
                <a href="#squad" class="px-4 py-2 text-[11px] font-semibold uppercase tracking-[0.16em] text-txt-2 hover:text-txt rounded-md hover:bg-black/10 dark:hover:bg-white/[0.04] transition-all duration-200">Squad</a>
                <a href="#fixtures" class="px-4 py-2 text-[11px] font-semibold uppercase tracking-[0.16em] text-txt-2 hover:text-txt rounded-md hover:bg-black/10 dark:hover:bg-white/[0.04] transition-all duration-200">Fixtures</a>
                <a href="#honours" class="px-4 py-2 text-[11px] font-semibold uppercase tracking-[0.16em] text-txt-2 hover:text-txt rounded-md hover:bg-black/10 dark:hover:bg-white/[0.04] transition-all duration-200">Honours</a>
            </div>

            <!-- Theme Toggle & Mobile burger -->
            <div class="flex items-center gap-3">
                <button id="theme-btn" class="w-9 h-9 rounded-full flex items-center justify-center text-txt hover:bg-black/10 transition-colors" aria-label="Toggle Theme">
                    <!-- Sun icon -->
                    <svg class="w-4 h-4 sm:w-5 sm:h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <circle cx="12" cy="12" r="5"></circle>
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 1v2m0 18v2M4.22 4.22l1.42 1.42m12.72 12.72l1.42 1.42M1 12h2m18 0h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"></path>
                    </svg>
                </button>
                <button id="mob-btn" class="md:hidden relative z-[100] w-9 h-9 flex items-center justify-center" aria-label="Menu">
                    <svg id="burger-svg" class="w-5 h-5 text-txt" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <line id="bline1" x1="4" y1="8" x2="20" y2="8" class="transition-all duration-300 origin-center" />
                        <line id="bline2" x1="4" y1="16" x2="20" y2="16" class="transition-all duration-300 origin-center" />
                    </svg>
                </button>
            </div>
        </div>
    </div>
</nav>

<!-- Mobile overlay -->
<div id="mob-menu" class="fixed inset-0 z-[89] bg-bg/95 backdrop-blur-2xl flex flex-col items-center justify-center gap-8 opacity-0 pointer-events-none transition-opacity duration-300 md:hidden">
    <a href="#squad" class="mob-link text-3xl font-display font-bold text-txt hover:text-lime transition-colors">Squad</a>
    <a href="#fixtures" class="mob-link text-3xl font-display font-bold text-txt hover:text-lime transition-colors">Fixtures</a>
    <a href="#honours" class="mob-link text-3xl font-display font-bold text-txt hover:text-lime transition-colors">Honours</a>
    <div class="mt-4 w-6 h-px bg-stroke-2"></div>
    <span class="text-[10px] font-medium tracking-[0.3em] uppercase text-txt-3">Drop 11 Cricket Club</span>
</div>

<script is:inline>
(() => {
    const btn = document.getElementById('mob-btn');
    const menu = document.getElementById('mob-menu');
    const l1 = document.getElementById('bline1');
    const l2 = document.getElementById('bline2');
    const nav = document.getElementById('site-nav');
    const mlinks = document.querySelectorAll('.mob-link');
    let open = false;

    function toggle() {
        open = !open;
        if (open) {
            menu.classList.remove('opacity-0','pointer-events-none');
            menu.classList.add('opacity-100','pointer-events-auto');
            // Proper X: rotate lines from center of the SVG
            l1.setAttribute('x1','5'); l1.setAttribute('y1','5');
            l1.setAttribute('x2','19'); l1.setAttribute('y2','19');
            l2.setAttribute('x1','5'); l2.setAttribute('y1','19');
            l2.setAttribute('x2','19'); l2.setAttribute('y2','5');
            document.body.style.overflow = 'hidden';
        } else {
            menu.classList.add('opacity-0','pointer-events-none');
            menu.classList.remove('opacity-100','pointer-events-auto');
            l1.setAttribute('x1','4'); l1.setAttribute('y1','8');
            l1.setAttribute('x2','20'); l1.setAttribute('y2','8');
            l2.setAttribute('x1','4'); l2.setAttribute('y1','16');
            l2.setAttribute('x2','20'); l2.setAttribute('y2','16');
            document.body.style.overflow = '';
        }
    }

    btn?.addEventListener('click', toggle);
    mlinks.forEach(l => l.addEventListener('click', () => { if(open) toggle(); }));

    // Theme toggle
    const themeBtn = document.getElementById('theme-btn');
    themeBtn?.addEventListener('click', () => {
        document.body.classList.toggle('light-theme');
    });

    // Frosted nav on scroll
    let ticking = false;
    window.addEventListener('scroll', () => {
        if (!ticking) {
            requestAnimationFrame(() => {
                if (window.scrollY > 40) {
                    nav.style.background = 'rgba(5,5,7,0.85)';
                    nav.style.backdropFilter = 'blur(16px) saturate(1.4)';
                    nav.style.webkitBackdropFilter = 'blur(16px) saturate(1.4)';
                    nav.style.borderBottomColor = 'rgba(255,255,255,0.05)';
                } else {
                    nav.style.background = 'transparent';
                    nav.style.backdropFilter = 'none';
                    nav.style.webkitBackdropFilter = 'none';
                    nav.style.borderBottomColor = 'transparent';
                }
                ticking = false;
            });
            ticking = true;
        }
    }, { passive: true });
})();
</script>
