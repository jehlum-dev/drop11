---
import awards from '../data/awards.json';

const resolvePath = (p) => {
    if (!p) return '';
    if (p.startsWith('http')) return p;
    const base = import.meta.env.BASE_URL.replace(/\/$/, '');
    return `${base}/${p.replace(/^\//, '')}`;
};
---
<section id="honours" class="py-20 md:py-32">
    <div class="max-w-[1200px] mx-auto px-5 sm:px-8 md:px-10 lg:px-12">

        <!-- Header -->
        <div class="reveal mb-12 md:mb-16">
            <span class="text-lime text-[11px] font-semibold tracking-[0.25em] uppercase block mb-2">Our Legacy</span>
            <h2 class="font-display font-bold text-4xl sm:text-5xl md:text-6xl tracking-tight text-txt">Honours</h2>
        </div>

        <!-- Awards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-5 stagger">
            {awards.map((a, i) => (
                <div class="reveal group glow-card hover:-translate-y-1 transition-transform duration-500" style={`--i:${i}`}>
                    <div class="glow-card-inner flex flex-col">
                        <!-- Image -->
                        <div class="relative aspect-[4/5] overflow-hidden bg-black">
                            <img
                                src={resolvePath(a.imgUrl)}
                                alt={a.title}
                                class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-700 ease-out"
                                loading="lazy"
                            />
                            <div class="absolute inset-0 bg-gradient-to-t from-surface via-transparent to-black/20 pointer-events-none"></div>
                            <!-- Badge -->
                            <div class="absolute top-3 left-3 px-3 py-1 rounded-full bg-lime">
                                <span class="text-[9px] font-bold tracking-[0.08em] uppercase text-black">🏆 Award</span>
                            </div>
                        </div>
                        <!-- Info -->
                        <div class="px-4 py-4 sm:px-5 sm:py-5 border-t border-stroke">
                            <h3 class="text-sm sm:text-[15px] font-display font-semibold text-txt tracking-wide group-hover:text-lime transition-colors duration-300 mb-1">
                                {a.title}
                            </h3>
                            <p class="text-[10px] font-medium tracking-[0.12em] uppercase text-txt-3">{a.subtext}</p>
                        </div>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
