---
import awards from '../data/awards.json';

const resolvePath = (p) => {
    if (!p) return '';
    if (p.startsWith('http')) return p;
    const base = import.meta.env.BASE_URL.replace(/\/$/, '');
    return `${base}/${p.replace(/^\//, '')}`;
};
---
<section id="honours" class="py-24 md:py-32 relative">
    <div class="px-6 md:px-12 max-w-[1400px] mx-auto">
        <div class="mb-16 md:mb-24 relative z-10">
            <span class="text-brand-accent font-bold tracking-[0.2em] uppercase text-xs mb-4 block">Our Legacy</span>
            <h2 class="text-5xl md:text-7xl font-serif italic tracking-tight text-brand-text max-w-2xl">Honours & History</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-12 md:gap-16 relative z-10">
            {awards.map((a) => (
                <div class="group cursor-pointer">
                    <!-- Image with extremely smooth parallax/scale hover -->
                    <div class="aspect-[4/5] md:aspect-square overflow-hidden mb-8 bg-black/50 rounded-xl border border-white/5">
                        <img src={resolvePath(a.imgUrl)} alt={a.title} class="w-full h-full object-cover filter grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-[1.03] transition-all duration-1000 ease-apple" />
                    </div>
                    <!-- Details -->
                    <div class="flex flex-col items-center text-center">
                        <h3 class="text-2xl md:text-3xl font-serif tracking-tight text-brand-text mb-3">{a.title}</h3>
                        <p class="text-xs font-bold tracking-[0.2em] uppercase text-brand-text-muted">{a.subtext}</p>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
