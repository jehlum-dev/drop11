---
const { id, name, role, class_spec, imgUrl } = Astro.props;
const delay = Astro.props.delay || 0;
---
<div data-aos="fade-up" data-aos-delay={delay} class="group border-b border-monolith-border pb-8 hover:border-white transition-colors duration-500">
    <div class="flex justify-between items-end mb-4">
        <div class="font-mono text-[9px] tracking-[0.4em] text-monolith-muted uppercase">{id}</div>
        <div class="font-mono text-[9px] tracking-[0.4em] text-monolith-muted uppercase">{class_spec}</div>
    </div>
    
    <div class="grid grid-cols-2 gap-8 items-center">
        <div class="overflow-hidden bg-monolith-surface h-[200px]">
            <img src={imgUrl} alt={name} class="w-full h-full object-cover grayscale opacity-50 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700 ease-out">
        </div>
        <div>
            <h3 class="text-3xl font-light tracking-[0.2em] uppercase mb-4 group-hover:pl-4 transition-all duration-500">{name}</h3>
            <p class="font-mono text-[10px] tracking-[0.3em] uppercase text-monolith-muted">{role}</p>
        </div>
    </div>
</div>
