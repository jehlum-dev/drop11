---
const { name, imgUrl } = Astro.props;
// Ensure paths resolve correctly on GitHub Pages
const resolvePath = (p) => {
    if (!p) return 'https://images.unsplash.com/photo-1543610892-0b1f7e6d8ac1?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80';
    if (p.startsWith('http')) return p;
    const base = import.meta.env.BASE_URL.replace(/\/$/, '');
    return `${base}/${p.replace(/^\//, '')}`;
};
---
<div class="player-card group relative flex flex-col cursor-pointer w-full bg-black/40 backdrop-blur-md rounded-xl overflow-hidden shadow-[0_4px_20px_rgba(0,0,0,0.3)] hover:shadow-[0_20px_40px_rgba(56,189,248,0.2)] active:shadow-[0_20px_40px_rgba(56,189,248,0.2)] transition-all duration-700 ease-apple border border-white/5 hover:border-brand-accent/50 active:border-brand-accent/50" ontouchstart="">
    
    <!-- Player Image Wrapper -->
    <div class="relative w-full aspect-[4/5] overflow-hidden bg-black/50">
        <img src={resolvePath(imgUrl)} 
             alt={name} 
             class="w-full h-full object-cover filter grayscale contrast-110 group-hover:grayscale-0 group-active:grayscale-0 transition-all duration-700 ease-apple group-hover:scale-[1.03] group-active:scale-[1.03]" />
             
        <!-- Subtle Hover Gradient -->
        <div class="absolute inset-0 bg-gradient-to-t from-black/50 via-transparent to-transparent opacity-0 group-hover:opacity-100 group-active:opacity-100 transition-opacity duration-700 ease-apple"></div>
    </div>
    
    <!-- Player Info (No numbering) -->
    <div class="relative z-20 p-6 md:p-8 bg-black/40 flex flex-col items-center text-center border-t border-white/5">
        <h3 class="text-2xl md:text-3xl font-serif tracking-tight text-brand-text mb-2 transform group-hover:-translate-y-1 group-active:-translate-y-1 transition-transform duration-500 ease-apple">{name}</h3>
        <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-brand-text-muted group-hover:text-brand-accent group-active:text-brand-accent transition-colors duration-300">View Details</span>
    </div>
</div>
