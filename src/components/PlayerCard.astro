---
const { id, name, role, status } = Astro.props;
const delay = Astro.props.delay || 0;
const imgUrl = `https://placehold.co/400x500/030504/39ff14?text=${id}&font=oswald`;
---
<div data-aos="fade-up" data-aos-delay={delay} class="player-card relative bg-alien-bg border border-alien-neon/20 p-1 group cursor-crosshair overflow-hidden clip-path-card">
    <div class="scanline z-20 pointer-events-none"></div>
    <div class="relative overflow-hidden grayscale group-hover:grayscale-0 transition-all duration-700">
        <img src={imgUrl} alt={name} class="w-full h-[300px] object-cover opacity-70 group-hover:opacity-100 group-hover:scale-110 transition-all duration-700">
        <div class="absolute inset-0 bg-gradient-to-t from-black via-transparent to-transparent z-10"></div>
        <div class="absolute top-4 right-4 bg-alien-neon text-black font-space text-xs font-bold px-2 py-1 z-20 transform translate-x-12 group-hover:translate-x-0 transition-transform duration-300">
            {id}
        </div>
    </div>
    <div class="p-6 relative z-20 bg-alien-bg/90 backdrop-blur-sm border-t border-alien-neon/30 mt-[-20px] group-hover:bg-alien-neon group-hover:text-black transition-colors duration-500">
        <h3 class="font-orbitron text-2xl font-bold tracking-widest mb-1 uppercase">{name}</h3>
        <div class="flex justify-between items-end">
            <p class="font-space text-sm opacity-70 group-hover:opacity-100 uppercase">{role}</p>
            <p class={`font-space text-[10px] uppercase ${status.includes('Optimal') ? 'text-alien-cyan' : 'text-alien-purple'} group-hover:text-black`}>
                SYS: {status}
            </p>
        </div>
    </div>
</div>
