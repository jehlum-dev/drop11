---
const { name, imgUrl } = Astro.props;
// Ensure paths resolve correctly on GitHub Pages
const resolvePath = (p) => {
    if (!p) return 'https://images.unsplash.com/photo-1543610892-0b1f7e6d8ac1?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80';
    if (p.startsWith('http')) return p;
    const base = import.meta.env.BASE_URL.replace(/\/$/, '');
    return `${base}/${p.replace(/^\//, '')}`;
};
---
<div class="group relative flex flex-col w-full rounded-[14px] overflow-hidden cursor-pointer shadow-[0_8px_30px_rgb(0,0,0,0.8)] hover:-translate-y-2 transition-all duration-700 p-[2px]">
    
    <!-- Spinning Glowing Light (Runs continuously, works on all devices) -->
    <div class="absolute top-[-50%] left-[-50%] w-[200%] h-[200%] animate-[spin_5s_linear_infinite] md:animate-[spin_8s_linear_infinite] z-0 pointer-events-none"
         style="background: conic-gradient(from 0deg, transparent 0deg, transparent 280deg, rgba(204,255,0,0.3) 330deg, #ccff00 360deg);">
    </div>
    
    <!-- Dark Inner Card (Leaves exactly 2px for the spinning border to show) -->
    <div class="relative z-10 w-full h-full bg-[#07070a] rounded-[12px] flex flex-col overflow-hidden">
        
        <!-- Player Image Wrapper -->
        <div class="relative w-full aspect-[4/5] bg-black overflow-hidden">
            <img src={resolvePath(imgUrl)} 
                 alt={name} 
                 class="w-full h-full object-cover group-hover:scale-105 transition-all duration-700 ease-in-out" />
            
            <div class="absolute inset-0 bg-gradient-to-t from-[#07070a] via-transparent to-black/30 z-20 pointer-events-none"></div>
        </div>
        
        <!-- Player Info -->
        <div class="relative z-30 p-6 md:p-8 bg-[#07070a] flex flex-col items-center text-center border-t border-white/5">
            <h3 class="text-2xl md:text-3xl font-serif tracking-widest text-brand-text mb-3 drop-shadow-[0_5px_5px_rgba(0,0,0,1)] group-hover:text-brand-accent transition-colors duration-500">
                {name}
            </h3>
            
            <div class="w-6 h-[1px] bg-white/20 mb-3 group-hover:bg-brand-accent group-hover:scale-150 transition-all duration-500"></div>
            
            <span class="text-[9px] font-bold uppercase tracking-[0.4em] text-white/50 drop-shadow-[0_2px_2px_rgba(0,0,0,1)]">Squad Member</span>
        </div>
    </div>
</div>

<style>
    /* No complex masks or clipping required. Using Tailwind's animate-[spin_4s_linear_infinite] */
</style>
