---
---
<div class="relative w-32 h-40 cursor-pointer group mx-auto" style="perspective: 1000px;">
    <!-- Text prompt -->
    <div class="absolute -top-12 left-1/2 transform -translate-x-1/2 font-mono text-xs uppercase tracking-widest text-monolith-muted opacity-0 group-hover:opacity-100 transition-opacity duration-300">
        Bowled!
    </div>
    
    <!-- Bails -->
    <div class="absolute top-0 left-3 w-12 h-2.5 bg-gradient-to-r from-amber-500 to-amber-700 rounded-full shadow-[0_5px_15px_rgba(0,0,0,0.5)] group-hover:-translate-y-24 group-hover:-translate-x-16 group-hover:-translate-z-10 group-hover:rotate-[-60deg] transition-all duration-[600ms] cubic-bezier(0.25, 1, 0.5, 1) z-10 origin-center"></div>
    <div class="absolute top-0 right-3 w-12 h-2.5 bg-gradient-to-r from-amber-500 to-amber-700 rounded-full shadow-[0_5px_15px_rgba(0,0,0,0.5)] group-hover:-translate-y-32 group-hover:translate-x-16 group-hover:translate-z-20 group-hover:rotate-[75deg] transition-all duration-[600ms] cubic-bezier(0.25, 1, 0.5, 1) z-10 origin-center"></div>
    
    <!-- Stumps -->
    <div class="absolute top-2 left-2 w-5 h-full bg-gradient-to-b from-amber-600 via-amber-700 to-amber-900 rounded-t-lg shadow-[inset_-2px_0_5px_rgba(0,0,0,0.5)] group-hover:rotate-[-20deg] group-hover:-translate-x-12 transition-all duration-500 ease-out origin-bottom"></div>
    <div class="absolute top-2 left-[52px] w-5 h-full bg-gradient-to-b from-amber-600 via-amber-700 to-amber-900 rounded-t-lg shadow-[inset_-2px_0_5px_rgba(0,0,0,0.5)] group-hover:rotate-[8deg] group-hover:translate-y-4 group-hover:-translate-z-[40px] transition-all duration-500 ease-out origin-bottom"></div>
    <div class="absolute top-2 right-2 w-5 h-full bg-gradient-to-b from-amber-600 via-amber-700 to-amber-900 rounded-t-lg shadow-[inset_-2px_0_5px_rgba(0,0,0,0.5)] group-hover:rotate-[35deg] group-hover:translate-x-16 group-hover:translate-z-[20px] transition-all duration-500 ease-out origin-bottom"></div>
</div>
