---
---
<div class="wicket-container relative w-32 h-40 cursor-pointer mx-auto" style="perspective: 1000px;" onclick="this.classList.toggle('is-broken')">
    <!-- Text prompt -->
    <div class="wicket-text absolute -top-12 left-1/2 transform -translate-x-1/2 font-mono text-xs uppercase tracking-widest text-monolith-muted opacity-0 transition-opacity duration-300">
        Bowled!
    </div>
    
    <!-- Bails -->
    <div class="wicket-bail-1 absolute top-0 left-3 w-12 h-2.5 bg-gradient-to-r from-amber-500 to-amber-700 rounded-full shadow-[0_5px_15px_rgba(0,0,0,0.5)] transition-all duration-[600ms] ease-out z-10 origin-center"></div>
    <div class="wicket-bail-2 absolute top-0 right-3 w-12 h-2.5 bg-gradient-to-r from-amber-500 to-amber-700 rounded-full shadow-[0_5px_15px_rgba(0,0,0,0.5)] transition-all duration-[600ms] ease-out z-10 origin-center"></div>
    
    <!-- Stumps -->
    <div class="wicket-stump-1 absolute top-2 left-2 w-5 h-full bg-gradient-to-b from-amber-600 via-amber-700 to-amber-900 rounded-t-lg shadow-[inset_-2px_0_5px_rgba(0,0,0,0.5)] transition-all duration-500 ease-out origin-bottom"></div>
    <div class="wicket-stump-2 absolute top-2 left-[52px] w-5 h-full bg-gradient-to-b from-amber-600 via-amber-700 to-amber-900 rounded-t-lg shadow-[inset_-2px_0_5px_rgba(0,0,0,0.5)] transition-all duration-500 ease-out origin-bottom"></div>
    <div class="wicket-stump-3 absolute top-2 right-2 w-5 h-full bg-gradient-to-b from-amber-600 via-amber-700 to-amber-900 rounded-t-lg shadow-[inset_-2px_0_5px_rgba(0,0,0,0.5)] transition-all duration-500 ease-out origin-bottom"></div>
</div>
