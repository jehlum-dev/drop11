---
<!-- Scroll-driven Rolling Ball -->
<div id="rolling-ball-wrapper" class="fixed right-4 md:right-16 w-32 h-32 md:w-48 md:h-48 z-40 pointer-events-none" style="top: 100px;">
    <!-- The ball itself which rotates -->
    <div id="rolling-ball" class="relative w-full h-full rounded-full shadow-2xl transition-transform duration-75 ease-linear">
        <img id="scroll-ball-red" src="/red_ball.png" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-500" alt="Red Ball" />
        <img id="scroll-ball-pink" src="/pink_ball.png" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-500 opacity-0" alt="Pink Ball" />
        <img id="scroll-ball-white" src="/white_ball.png" class="absolute inset-0 w-full h-full object-cover transition-opacity duration-500 opacity-0" alt="White Ball" />
    </div>
</div>

<script is:inline>
    // Run client-side
    document.addEventListener('DOMContentLoaded', () => {
        const wrapper = document.getElementById('rolling-ball-wrapper');
        const ball = document.getElementById('rolling-ball');
        const red = document.getElementById('scroll-ball-red');
        const pink = document.getElementById('scroll-ball-pink');
        const white = document.getElementById('scroll-ball-white');
        
        if (!wrapper || !ball) return;
        
        window.addEventListener('scroll', () => {
            const scrollY = window.scrollY;
            
            // Calculate how far down the page we are (0.0 to 1.0)
            const maxScroll = Math.max(1, document.documentElement.scrollHeight - window.innerHeight);
            const scrollFraction = scrollY / maxScroll;
            
            // 1. Roll the ball vertically down the viewport
            // Subtract ball height (approx 192px on desktop) so it doesn't roll off screen
            const ballHeight = window.innerWidth > 768 ? 192 : 128;
            const availableViewportHeight = window.innerHeight - ballHeight - 150; // 150px padding
            const translateY = scrollFraction * availableViewportHeight;
            
            // Apply vertical movement to wrapper
            wrapper.style.transform = `translateY(${translateY}px)`;
            
            // 2. Rotate the ball to simulate rolling (spin speed)
            const rotation = scrollY * 0.4;
            ball.style.transform = `rotate(${rotation}deg)`;
            
            // 3. Seamlessly transition ball colors as we scroll
            if (scrollFraction < 0.33) {
                red.style.opacity = '1';
                pink.style.opacity = '0';
                white.style.opacity = '0';
            } else if (scrollFraction >= 0.33 && scrollFraction < 0.66) {
                red.style.opacity = '0';
                pink.style.opacity = '1';
                white.style.opacity = '0';
            } else {
                red.style.opacity = '0';
                pink.style.opacity = '0';
                white.style.opacity = '1';
            }
        });
    });
</script>
