---
const resolvePath = (p) => {
    const base = import.meta.env.BASE_URL.replace(/\/$/, '');
    return `${base}/${p.replace(/^\//, '')}`;
};
---

<div id="rolling-ball-wrapper" class="fixed left-0 top-0 w-20 h-20 md:w-28 md:h-28 z-[80]">
    <div id="rolling-ball" class="relative w-full h-full rounded-full cursor-grab active:cursor-grabbing transition-transform duration-75 ease-linear hover:shadow-[0_15px_30px_rgba(227,38,54,0.4)]" style="filter: drop-shadow(0 8px 20px rgba(0,0,0,0.5));">
        <img id="scroll-ball-red" src={resolvePath("red_ball.png")} class="absolute inset-0 w-full h-full object-cover transition-opacity duration-500 pointer-events-none" alt="Red Ball" />
        <img id="scroll-ball-pink" src={resolvePath("pink_ball.png")} class="absolute inset-0 w-full h-full object-cover transition-opacity duration-500 opacity-0 pointer-events-none" alt="Pink Ball" />
        <img id="scroll-ball-white" src={resolvePath("white_ball.png")} class="absolute inset-0 w-full h-full object-cover transition-opacity duration-500 opacity-0 pointer-events-none" alt="White Ball" />
    </div>
</div>

<script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
        const wrapper = document.getElementById('rolling-ball-wrapper');
        const ball = document.getElementById('rolling-ball');
        const red = document.getElementById('scroll-ball-red');
        const pink = document.getElementById('scroll-ball-pink');
        const white = document.getElementById('scroll-ball-white');
        if (!wrapper || !ball) return;

        const isMobile = window.innerWidth < 768;
        const initialTop = isMobile ? (window.innerHeight * 0.4) : 150;
        const sidePadding = isMobile ? 16 : 32;
        const bottomPadding = 60;
        const ballWidth = isMobile ? 80 : 112;

        // Same 1200px container boundaries as the rest of the site
        function getContainerLeft() { return window.innerWidth > 1200 ? (window.innerWidth - 1200) / 2 : 0; }
        function getContainerWidth() { return window.innerWidth > 1200 ? 1200 : window.innerWidth; }

        let offsetX = getContainerLeft() + getContainerWidth() - sidePadding - ballWidth;
        let offsetY = initialTop;

        let isDragging = false;
        let startX, startY, initialOffsetX, initialOffsetY;
        let velocityX = (Math.random() - 0.5) * 10;
        let velocityY = 0;
        let lastMouseX = 0, lastMouseY = 0;
        let rotation = 0;
        let currentBigBallColor = 0;
        let lastColorChange = 0;

        function cycleBigBallColor() {
            const now = Date.now();
            if (now - lastColorChange < 200) return;
            lastColorChange = now;
            currentBigBallColor = (currentBigBallColor + 1) % 3;
            red.style.opacity = currentBigBallColor === 0 ? '1' : '0';
            pink.style.opacity = currentBigBallColor === 1 ? '1' : '0';
            white.style.opacity = currentBigBallColor === 2 ? '1' : '0';
        }

        window.addEventListener('mousemove', (e) => {
            const mouseVx = e.clientX - lastMouseX;
            const mouseVy = e.clientY - lastMouseY;
            lastMouseX = e.clientX;
            lastMouseY = e.clientY;
            if (isDragging) {
                offsetX = initialOffsetX + (e.clientX - startX);
                offsetY = initialOffsetY + (e.clientY - startY);
                velocityX = mouseVx;
                velocityY = mouseVy;
            }
        });

        ball.addEventListener('mousedown', (e) => {
            e.preventDefault();
            isDragging = true;
            startX = e.clientX; startY = e.clientY;
            initialOffsetX = offsetX; initialOffsetY = offsetY;
            lastMouseX = e.clientX; lastMouseY = e.clientY;
            ball.style.transform = `scale(1.1) rotate(${rotation}deg)`;
        });

        window.addEventListener('mouseup', () => {
            if (isDragging) {
                isDragging = false;
                ball.style.transform = `scale(1) rotate(${rotation}deg)`;
            }
        });

        ball.addEventListener('touchstart', (e) => {
            e.preventDefault();
            isDragging = true;
            startX = e.touches[0].clientX; startY = e.touches[0].clientY;
            initialOffsetX = offsetX; initialOffsetY = offsetY;
            lastMouseX = startX; lastMouseY = startY;
        }, { passive: false });

        window.addEventListener('touchmove', (e) => {
            if (isDragging) {
                e.preventDefault();
                const tx = e.touches[0].clientX;
                const ty = e.touches[0].clientY;
                offsetX = initialOffsetX + (tx - startX);
                offsetY = initialOffsetY + (ty - startY);
                velocityX = tx - lastMouseX;
                velocityY = ty - lastMouseY;
                lastMouseX = tx;
                lastMouseY = ty;
            }
        }, { passive: false });

        window.addEventListener('touchend', () => isDragging = false);

        function physicsLoop() {
            const ballHeight = ballWidth;
            const cLeft = getContainerLeft();
            const cWidth = getContainerWidth();
            const minX = cLeft + sidePadding;
            const maxX = cLeft + cWidth - sidePadding - ballWidth;
            const minY = sidePadding;
            const maxY = window.innerHeight - bottomPadding - ballHeight;

            if (!isDragging) {
                velocityY += 0.8;
                velocityX *= 0.99;
                velocityY *= 0.99;
                offsetX += velocityX;
                offsetY += velocityY;

                let hitWall = false;
                if (offsetY > maxY) { offsetY = maxY; velocityY *= -0.75; velocityX *= 0.9; if (Math.abs(velocityY) > 2) hitWall = true; }
                else if (offsetY < minY) { offsetY = minY; velocityY *= -0.8; if (Math.abs(velocityY) > 2) hitWall = true; }
                if (offsetX < minX) { offsetX = minX; velocityX *= -0.8; if (Math.abs(velocityX) > 2) hitWall = true; }
                else if (offsetX > maxX) { offsetX = maxX; velocityX *= -0.8; if (Math.abs(velocityX) > 2) hitWall = true; }

                if (hitWall) cycleBigBallColor();
            } else {
                if (offsetX < cLeft + sidePadding) offsetX = cLeft + sidePadding;
                if (offsetX > cLeft + cWidth - sidePadding - ballWidth) offsetX = cLeft + cWidth - sidePadding - ballWidth;
                if (offsetY < sidePadding) offsetY = sidePadding;
                if (offsetY > window.innerHeight - bottomPadding - ballHeight) offsetY = window.innerHeight - bottomPadding - ballHeight;
            }

            wrapper.style.transform = `translate(${offsetX}px, ${offsetY}px)`;
            if (!isDragging) {
                rotation += velocityX * 2;
                ball.style.transform = `scale(1) rotate(${rotation}deg)`;
            }
            requestAnimationFrame(physicsLoop);
        }

        wrapper.style.transform = `translate(${offsetX}px, ${offsetY}px)`;

        window.addEventListener('resize', () => {
            const m = window.innerWidth < 768;
            const sPad = m ? 16 : 32;
            const bPad = 60;
            const w = m ? 80 : 112;
            const cLeft = getContainerLeft();
            const cWidth = getContainerWidth();
            const maxX = cLeft + cWidth - sPad - w;
            const maxY = window.innerHeight - bPad - w;
            if (offsetX > maxX) offsetX = maxX;
            if (offsetX < cLeft + sPad) offsetX = cLeft + sPad;
            if (offsetY > maxY) offsetY = maxY;
        });

        physicsLoop();
    });
</script>
