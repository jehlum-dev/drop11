---
const resolvePath = (p) => {
    return import.meta.env.BASE_URL + p.replace(/^\//, '');
};
---
<!-- Scroll-driven and Draggable Rolling Ball - MADE SMALLER -->
<div id="rolling-ball-wrapper" class="fixed right-4 md:right-8 w-20 h-20 md:w-28 md:h-28 z-[100] top-[40vh] md:top-[150px]">
    <!-- The ball itself which rotates and scales -->
    <div id="rolling-ball" class="relative w-full h-full rounded-full shadow-lg transition-transform duration-75 ease-linear cursor-grab active:cursor-grabbing hover:shadow-[0_15px_30px_rgba(227,38,54,0.4)]">
        <img id="scroll-ball-red" src={resolvePath("red_ball.png")} class="absolute inset-0 w-full h-full object-cover transition-opacity duration-500 pointer-events-none" alt="Red Ball" />
        <img id="scroll-ball-pink" src={resolvePath("pink_ball.png")} class="absolute inset-0 w-full h-full object-cover transition-opacity duration-500 opacity-0 pointer-events-none" alt="Pink Ball" />
        <img id="scroll-ball-white" src={resolvePath("white_ball.png")} class="absolute inset-0 w-full h-full object-cover transition-opacity duration-500 opacity-0 pointer-events-none" alt="White Ball" />
    </div>
</div>

<script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
        const wrapper = document.getElementById('rolling-ball-wrapper');
        const ball = document.getElementById('rolling-ball');
        const red = document.getElementById('scroll-ball-red');
        const pink = document.getElementById('scroll-ball-pink');
        const white = document.getElementById('scroll-ball-white');
        
        if (!wrapper || !ball) return;
        
        let offsetX = 0; let offsetY = 0;
        let isDragging = false;
        let startX, startY, initialOffsetX, initialOffsetY;
        let currentScrollY = window.scrollY;
        
        let velocityX = 0; let velocityY = 0;
        let lastX = 0; let lastY = 0;
        let animationFrameId = null;

        function updateBallPosition() {
            const maxScroll = Math.max(1, document.documentElement.scrollHeight - window.innerHeight);
            const scrollFraction = currentScrollY / maxScroll;
            
            const isMobile = window.innerWidth < 768;
            const initialTop = isMobile ? (window.innerHeight * 0.4) : 150;
            const ballHeight = isMobile ? 80 : 112; // Adjusted for smaller ball
            const paddingBottom = 40;
            
            const availableViewportHeight = window.innerHeight - initialTop - ballHeight - paddingBottom;
            const finalY = (scrollFraction * availableViewportHeight) + offsetY;
            
            wrapper.style.transform = `translate(${offsetX}px, ${finalY}px)`;
            
            const rotation = (currentScrollY * 0.5) + (offsetX * 0.8);
            ball.style.transform = isDragging ? `scale(1.1) rotate(${rotation}deg)` : `scale(1) rotate(${rotation}deg)`;
            
            if (scrollFraction < 0.33) {
                red.style.opacity = '1'; pink.style.opacity = '0'; white.style.opacity = '0';
            } else if (scrollFraction >= 0.33 && scrollFraction < 0.66) {
                red.style.opacity = '0'; pink.style.opacity = '1'; white.style.opacity = '0';
            } else {
                red.style.opacity = '0'; pink.style.opacity = '0'; white.style.opacity = '1';
            }
        }

        function handleDragStart(clientX, clientY) {
            isDragging = true;
            startX = clientX; startY = clientY;
            lastX = clientX; lastY = clientY;
            initialOffsetX = offsetX; initialOffsetY = offsetY;
            if (animationFrameId) cancelAnimationFrame(animationFrameId);
            updateBallPosition();
        }

        function handleDragMove(clientX, clientY) {
            if (!isDragging) return;
            offsetX = initialOffsetX + (clientX - startX);
            offsetY = initialOffsetY + (clientY - startY);
            velocityX = clientX - lastX; velocityY = clientY - lastY;
            lastX = clientX; lastY = clientY;
            updateBallPosition();
        }

        function handleDragEnd() {
            if (!isDragging) return;
            isDragging = false;
            applyInertia();
        }

        ball.addEventListener('mousedown', (e) => { e.preventDefault(); handleDragStart(e.clientX, e.clientY); });
        window.addEventListener('mousemove', (e) => handleDragMove(e.clientX, e.clientY));
        window.addEventListener('mouseup', handleDragEnd);

        ball.addEventListener('touchstart', (e) => { e.preventDefault(); handleDragStart(e.touches[0].clientX, e.touches[0].clientY); }, { passive: false });
        window.addEventListener('touchmove', (e) => { if (isDragging) { e.preventDefault(); handleDragMove(e.touches[0].clientX, e.touches[0].clientY); } }, { passive: false });
        window.addEventListener('touchend', handleDragEnd);
        
        function applyInertia() {
            if (Math.abs(velocityX) < 0.5 && Math.abs(velocityY) < 0.5) { updateBallPosition(); return; }
            velocityX *= 0.92; velocityY *= 0.92;
            offsetX += velocityX; offsetY += velocityY;
            updateBallPosition();
            if (Math.abs(velocityX) > 0.1 || Math.abs(velocityY) > 0.1) {
                animationFrameId = requestAnimationFrame(applyInertia);
            }
        }

        window.addEventListener('scroll', () => { currentScrollY = window.scrollY; updateBallPosition(); });
        updateBallPosition();
    });
</script>
