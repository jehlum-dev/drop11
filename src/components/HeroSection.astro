---
---
<header class="relative w-full min-h-[85vh] md:min-h-screen flex items-center justify-center overflow-hidden border-b border-stroke" id="hero">
    
    <!-- Grand Central Typography -->
    <div class="relative z-10 flex flex-col items-center justify-center w-full px-5 text-center mt-10">
        
        <div class="hero-el overflow-hidden mb-6 md:mb-8" style="--d:0ms">
            <span class="inline-block px-5 py-2 border border-lime/30 rounded-full text-lime text-[10px] font-bold tracking-[0.3em] uppercase bg-lime/5">
                The Official Home of Drop 11
            </span>
        </div>

        <h1 class="hero-el font-display font-black uppercase text-[5rem] sm:text-[7rem] md:text-[9.5rem] lg:text-[13rem] leading-[0.85] tracking-tighter text-txt drop-shadow-2xl" style="--d:150ms">
            DROP <span class="text-lime inline-block hover:scale-105 transition-transform duration-500">XI</span>
        </h1>

        <!-- Elegant Horizontal Urdu Poetry -->
        <div class="hero-el mt-8 md:mt-12 mb-4 max-w-2xl px-4" style="--d:300ms">
            <p class="text-2xl md:text-3xl text-txt font-light leading-relaxed text-center" style="font-family: 'Noto Nastaliq Urdu', serif;" dir="rtl">
                کوئی میرے دل سے پوچھے ترے تیر نیم کش کو<br class="hidden sm:block">
                <span class="text-lg md:text-xl text-txt-2 mt-2 block">یہ خلش کہاں سے ہوتی جو جگر کے پار ہوتا</span>
            </p>
        </div>

        <div class="hero-el mt-8 md:mt-10 flex flex-col items-center gap-8" style="--d:450ms">
            <p class="text-txt-2 text-xs sm:text-sm md:text-base font-medium tracking-[0.15em] uppercase max-w-lg leading-relaxed">
                Precision on the pitch. Elegance in our game.
            </p>
            
            <a href="#squad" class="group relative px-10 py-4 md:py-5 bg-transparent overflow-hidden rounded-full border-2 border-stroke hover:border-lime transition-colors duration-500">
                <div class="absolute inset-0 bg-lime translate-y-[100%] group-hover:translate-y-0 transition-transform duration-500 ease-in-out"></div>
                <span class="relative z-10 text-xs font-bold uppercase tracking-[0.2em] text-txt group-hover:text-black transition-colors duration-500">
                    Explore The Roster
                </span>
            </a>
        </div>
    </div>

</header>

<style>
    .hero-el {
        opacity: 0;
        transform: translateY(30px);
        animation: heroFadeUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        animation-delay: var(--d, 0ms);
    }
    @keyframes heroFadeUp {
        to { opacity: 1; transform: translateY(0); }
    }
</style>
