<header class="relative min-h-[90vh] flex flex-col justify-center items-center text-center px-6 md:px-12 border-b border-black/10 overflow-hidden">
    
    <!-- Poetry Text -->
    <div class="relative z-10 max-w-4xl mx-auto flex flex-col items-center">
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-serif italic tracking-tight leading-[1.1] text-brand-text mb-12 drop-shadow-sm">
            "koī mere dil se pūchhe tire tīr-e-nīm-kash ko<br>
            ye ḳhalish kahāñ se hotī jo jigar ke paar hotā"
        </h1>
        
        <div class="w-12 h-[2px] bg-brand-accent mb-8"></div>
        
        <p class="text-lg md:text-xl font-sans tracking-[0.2em] uppercase text-brand-text-muted font-medium">
            We are a simple cricket team.
        </p>
    </div>
    
    <!-- Decorative background elements -->
    <div class="absolute bottom-0 left-0 w-full overflow-hidden pointer-events-none opacity-[0.03]">
        <h2 class="text-[15vw] font-bold tracking-tighter leading-none whitespace-nowrap text-center">DROP 11</h2>
    </div>
</header>
