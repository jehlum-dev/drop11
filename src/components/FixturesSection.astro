---
import matches from '../data/matches.json';
---
<section id="fixtures" class="py-20 md:py-32 border-b border-stroke">
    <div class="max-w-[1200px] mx-auto px-5 sm:px-8 md:px-10 lg:px-12">

        <!-- Header -->
        <div class="reveal mb-12 md:mb-16">
            <span class="text-lime text-[11px] font-semibold tracking-[0.25em] uppercase block mb-2">Schedule</span>
            <h2 class="font-display font-bold text-4xl sm:text-5xl md:text-6xl tracking-tight text-txt">Match Fixtures</h2>
        </div>

        <!-- Matches -->
        <div class="flex flex-col gap-3">
            {matches.map((m, i) => (
                <div class="reveal group bg-surface rounded-2xl border border-stroke hover:border-lime/20 px-5 sm:px-6 md:px-8 py-5 md:py-6 flex flex-col md:flex-row items-start md:items-center gap-3 md:gap-6 transition-all duration-400 hover:shadow-[0_0_30px_rgba(204,255,0,0.04)] cursor-pointer" style={`--i:${i}`}>

                    <!-- Number -->
                    <div class="hidden md:flex items-center justify-center w-10 h-10 rounded-xl bg-lime/5 border border-lime/10 shrink-0">
                        <span class="text-xs font-bold text-lime/60 tabular-nums font-display">{String(i + 1).padStart(2, '0')}</span>
                    </div>

                    <!-- Date -->
                    <div class="md:w-[140px] shrink-0">
                        <span class="text-[11px] font-semibold tracking-[0.1em] uppercase text-txt-2">{m.date}</span>
                    </div>

                    <!-- Opponent -->
                    <div class="flex-1 min-w-0">
                        <h3 class="text-xl sm:text-2xl md:text-3xl font-display font-bold text-txt tracking-tight truncate group-hover:text-lime transition-colors duration-300">
                            vs {m.opponent}
                        </h3>
                    </div>

                    <!-- Status -->
                    <div class="shrink-0">
                        <span class={`inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-[10px] font-bold tracking-[0.12em] uppercase ${
                            m.status === 'WIN'
                                ? 'bg-won/10 text-won border border-won/20'
                                : m.status === 'LOSS'
                                    ? 'bg-lost/10 text-lost border border-lost/20'
                                    : 'bg-white/5 text-txt-2 border border-stroke'
                        }`}>
                            <span class={`w-1.5 h-1.5 rounded-full ${m.status === 'WIN' ? 'bg-won' : m.status === 'LOSS' ? 'bg-lost' : 'bg-txt-2'}`}></span>
                            {m.status}
                        </span>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
