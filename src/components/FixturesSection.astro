---
import matches from '../data/matches.json';
---
<section id="fixtures" class="py-24 md:py-32 border-b border-white/10 relative">
    <div class="px-6 md:px-12 max-w-7xl mx-auto">
        <div class="mb-16 md:mb-24 flex flex-col md:flex-row md:items-end justify-between gap-6">
            <div>
                <span class="text-brand-accent font-bold tracking-[0.2em] uppercase text-xs mb-4 block">Schedule</span>
                <h2 class="text-5xl md:text-7xl font-serif italic tracking-tight text-brand-text">Match Fixtures</h2>
            </div>
        </div>
        
        <div class="flex flex-col border-t border-white/10">
            {matches.map((m) => (
                <div class="group flex flex-col md:flex-row items-start md:items-center justify-between py-10 md:py-12 border-b border-white/10 hover:bg-white/5 px-6 md:px-10 -mx-6 md:-mx-10 transition-colors duration-500 ease-apple cursor-pointer rounded-xl">
                    <div class="w-full md:w-1/4 mb-4 md:mb-0">
                        <span class="text-xs font-bold tracking-[0.2em] uppercase text-brand-text-muted">{m.date}</span>
                    </div>
                    <div class="w-full md:w-1/2 mb-6 md:mb-0">
                        <h3 class="text-3xl md:text-5xl font-sans tracking-tight text-brand-text group-hover:translate-x-4 transition-transform duration-500 ease-apple">
                            vs {m.opponent}
                        </h3>
                    </div>
                    <div class="w-full md:w-1/4 flex md:justify-end">
                        <span class={`px-6 py-2 rounded-full text-xs font-bold tracking-widest uppercase transition-all duration-300 ${m.status === 'WIN' ? 'bg-brand-accent text-brand-bg shadow-md' : 'border border-white/20 text-brand-text'}`}>
                            {m.status}
                        </span>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
